# Copy to .env and fill in. .env is gitignored.

# Generate with: mix phx.gen.secret  (or: openssl rand -base64 48)
SECRET_KEY_BASE=replace-me-with-a-64+-char-secret

# Public hostname the coordinator is reached at (used for URL generation).
PHX_HOST=localhost

# Host port to publish the coordinator on.
PORT=4000

# Starter faucet (CC) granted to a new peer. Tiny by design, but generous for now
# while real credit-earning isn't wired yet.
FAUCET_CC=100000
